// A message with unsigned integer fields.
message UnsignedInts {

    // The first field.
    one u8 = 1;

    // The second field.
    twp u16 = 2;

    // The third field.
    three u32 = 3;

    // The fourth field.
    four u64 = 4;

    // The fifth field.
    five u128 = 5;
}

// A message with special field types.
message SpecialTypes {

    // A string typed field.
    one string = 1;

    // A UUID typed field.
    two uuid = 2;
}

// A message with named types.
message NamedTypes {

    // A sub-message with unsigned integers.
    unsigned_ints UnsignedInts = 1;
}
